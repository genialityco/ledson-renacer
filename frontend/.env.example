# Copiar este archivo a `.env` (o `env`) y completar los valores reales.

# URL pública del backend. Sin esta variable, se asume http://<host actual>:5000
# (funciona en desarrollo local y en la pantalla grande dentro de la LAN).
VITE_API_URL=

# Llave pública de Wompi (widget de pago, corre en el cliente).
VITE_WOMPI_PUBLIC_KEY=
