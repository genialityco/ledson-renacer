# Copiar este archivo a `.env` (o `env`) y completar los valores reales.
# No commitear el archivo con los valores reales.

# Puerto del servidor. DigitalOcean App Platform inyecta PORT automáticamente.
PORT=5000

# --- Firebase Admin SDK ---
# Opción A (recomendada para producción / DO App Platform): pegar aquí el JSON
# del service account codificado en base64. En PowerShell:
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("sured-883e9-firebase-adminsdk.json"))
FIREBASE_SERVICE_ACCOUNT_BASE64=
# Opción B (desarrollo local): si FIREBASE_SERVICE_ACCOUNT_BASE64 no está seteada,
# se lee el archivo sured-883e9-firebase-adminsdk.json en la raíz de backend/.
FIREBASE_STORAGE_BUCKET=

# --- CORS ---
# Lista de orígenes permitidos separados por coma (ej: https://mi-sitio.netlify.app).
# Si se deja vacío, CORS queda abierto (solo recomendado en desarrollo local).
ALLOWED_ORIGINS=

# --- API externa de generación de imágenes con IA ---
# Si no está seteada, usa http://localhost:8000. Si falla, se intenta con Gemini
# (ver abajo) y si Gemini también falla, se proyecta la foto original.
AI_GENERATION_API_URL=

# --- Gemini (alternativa si falla AI_GENERATION_API_URL) ---
# Usa las dos imágenes de referencia de cada filtro (referenceImageUrl1/2) más la
# foto de la persona para generar una imagen siguiendo ese estilo de arte.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-image

# --- dLocal Go ---
DLOCALGO_API_KEY=
DLOCALGO_API_SECRET=
# "production" o "sandbox" (default: sandbox)
DLOCALGO_ENV=sandbox

# --- Wompi ---
# "production" o "sandbox" (default: sandbox)
WOMPI_ENV=sandbox
WOMPI_PRIVATE_KEY_TEST=
WOMPI_PRIVATE_KEY_PROD=
WOMPI_INTEGRITY_SECRET_TEST=
WOMPI_INTEGRITY_SECRET_PROD=

# --- AWS SES (envío de emails) ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_EMAIL_FROM=
AWS_SES_EMAIL_FROM_NAME=

# --- WhatsApp ---
# URL pública del servicio que envía mensajes de WhatsApp.
WHATSAPP_API_URL=
WHATSAPP_ACCOUNT_ID=
